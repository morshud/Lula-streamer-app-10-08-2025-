{
    "expo": {
        "name": "Lula Streamer",
        "slug": "lula-streamer",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/images/icon.png",
        "userInterfaceStyle": "automatic",
        "splash": {
            "image": "./assets/images/splash-icon.png",
            "resizeMode": "cover",
            "backgroundColor": "#ffffff"
        },
        "assetBundlePatterns": [
            "**/*"
        ],
        "ios": {
            "supportsTablet": true
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/images/adaptive-icon.png",
                "backgroundColor": "#335EF7"
            },
            "package": "com.lula.streamer",
            "googleServicesFile": "./google-services.json",
            "permissions": [
                "android.permissions.CAMERA",
                "android.permissions.RECORD_AUDIO",
                "android.permissions.INTERNET",
                "android.permissions.MODIFY_AUDIO_SETTINGS",
                "android.permissions.BLUETOOTH",
                "android.permissions.BLUETOOTH_ADMIN",
                "android.permissions.BLUETOOTH_CONNECT",
                "android.permissions.BLUETOOTH_SCAN"
            ]
        },
        "web": {
            "favicon": "./assets/images/favicon.png"
        },
        "plugins": [
            "@stream-io/video-react-native-sdk",
            [
                "@config-plugins/react-native-webrtc",
                {
                    "cameraPermission": "$(PRODUCT_NAME) requires camera access in order to capture and transmit video",
                    "microphonePermission": "$(PRODUCT_NAME) requires microphone access in order to capture and transmit audio"
                }
            ],
            [
                "expo-build-properties",
                {
                    "ios": {
                        "useFrameworks": "static"
                    },
                    "android": {
                        "minSdkVersion": 24,
                        "extraMavenRepos": [
                            "../../node_modules/@notifee/react-native/android/libs"
                        ]
                    }
                }
            ],
            [
                "expo-camera",
                {
                    "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera",
                    "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone"
                }
            ]
        ]
    }
}